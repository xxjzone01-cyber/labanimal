{
  "name": "@labanimal/cli",
  "version": "0.1.0",
  "description": "LabAnimal CLI - 数据迁移工具",
  "type": "module",
  "bin": {
    "labanimal": "./dist/cli.js"
  },
  "main": "./dist/migrate.js",
  "types": "./dist/migrate.d.ts",
  "exports": {
    ".": {
      "types": "./dist/migrate.d.ts",
      "import": "./dist/migrate.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "commander": "^12.0.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "AGPL-3.0"
}
