# Database
DATABASE_URL=postgresql://labanimal:labanimal_dev@localhost:5432/labanimal

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=labanimal
MINIO_SECRET_KEY=labanimal_dev
MINIO_BUCKET=labanimal

# Auth (for production, override with real secrets)
AUTH_SECRET=dev-secret-change-in-production

# PayPal (sandbox credentials, replace for production)
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_ENV=sandbox
PAYPAL_PLAN_ACADEMIC_FREE=
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_PROFESSIONAL=
PAYPAL_PLAN_ENTERPRISE_SAAS=

# App URL (for PayPal return/cancel URLs)
APP_URL=http://localhost:3000
