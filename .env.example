# Database
DATABASE_URL=postgresql://labanimal:labanimal_dev@localhost:5432/labanimal

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=labanimal
MINIO_SECRET_KEY=labanimal_dev
MINIO_BUCKET=labanimal

# Auth (for production, override with real secrets)
AUTH_SECRET=dev-secret-change-in-production

# PayPal (sandbox credentials, replace for production)
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id
PAYPAL_PLAN_ACADEMIC_FREE=
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_PROFESSIONAL=
PAYPAL_PLAN_ENTERPRISE_SAAS=

# App URL (for PayPal return/cancel URLs)
APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=          # Resend API key
MAIL_FROM=               # 发件人地址，默认 LabAnimal <onboarding@resend.dev>

# Cron
CRON_SECRET=             # 定时任务端点认证密钥

# Monitoring
ALERT_EMAIL=             # 系统告警接收邮箱

# Backup (Tencent Cloud COS)
COS_BUCKET=              # COS 存储桶名称
COS_REGION=              # COS 区域（如 ap-guangzhou）
COS_SECRET_ID=           # 腾讯云 SecretId
COS_SECRET_KEY=          # 腾讯云 SecretKey
BACKUP_RETENTION_DAYS=30 # 本地备份保留天数
